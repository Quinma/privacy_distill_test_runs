# Core model settings
MODEL=EleutherAI/pythia-1.4b
STUDENT=EleutherAI/pythia-410m
RUN_TAG=my-audit-run
TOKENIZER=$MODEL

# Optional raw-corpus build settings.
# Skip gate/build entirely if you already have prebuilt datasets under DATASETS_DIR.
DATASET=your-org/your-corpus
CONFIG=default
REVISION=
SPLIT=train
DATA_FILES=
CIK_MAP=$ROOT/data/sec_index_10k.jsonl  # replace or remove if your builder does not use accession->entity mapping
FORM_TYPES=10-K
TEXT_FIELD=text
CIK_FIELD=cik
FORM_FIELD=type_filing
DATE_FIELD=date
STATS_PATH=$ROOT/data/corpus_stats.jsonl
TOP_N=100
N_TARGETS=50
HOLDOUT_MAX=5
HOLDOUT_FRAC=0.2
BACKGROUND_TOKENS=50000000
NONMEMBER_TOKENS=15000000
MAX_TOKENS_PER_COMPANY=500000
MIN_TOKENS=200000
LOG_EVERY=5000

# Output layout
DATASETS_DIR=$ROOT/data/datasets/$RUN_TAG
TEACHERS_DIR=$ROOT/outputs/$RUN_TAG/teachers
STUDENTS_DIR=$ROOT/outputs/$RUN_TAG/students
MIA_DIR=$ROOT/outputs/$RUN_TAG/mia

# Training / distillation / unlearning
MAX_LENGTH=512
BF16=1
TRAIN_BATCH=2
TRAIN_ACCUM=16
TRAIN_EPOCHS=3
TRAIN_LR=2e-5
WARMUP_STEPS=500
OPTIM=adamw_torch
WORKERS=4
VISIBLE_GPUS=0,1,2
TRAIN_GPU_C1=0
TRAIN_GPU_C2=1
TRAIN_GPU_C3=2
DISTILL_GPU_C1=0
DISTILL_GPU_C2=1
DISTILL_GPU_C3=2
UNLEARN_GPU=0
EVAL_GPU=0
UNLEARN_EPOCHS=3
UNLEARN_LR=2e-5
RETAIN_WEIGHT=1.0
NPO_BETA=0.1
DISTILL_TEACHER_DEVICE=cuda
DISTILL_TEACHER_DTYPE=auto

# Stage toggles for scripts/run_audit_pipeline.sh
RUN_GATE=0
RUN_BUILD=0
RUN_TRAIN=1
RUN_DISTILL=1
RUN_C6_NPO=1
RUN_STANDARD_EVAL=1
RUN_RETAIN_AUDIT=1

# Retain-pool audit inputs
RETAIN_HOLDOUT_DATASET=$ROOT/data/datasets/eval_retain_holdout
TARGET_HOLDOUT_DATASET=$DATASETS_DIR/eval_target_holdout
NONMEMBER_DATASET=$DATASETS_DIR/eval_nonmember
HOLDOUT_MAP=$DATASETS_DIR/holdout_map.json
SEED=13
